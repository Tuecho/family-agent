# Groq API Key (para el chatbot IA)
GROQ_API_KEY=tu_api_key_de_groq

# DuckDNS Token (para actualizaciones de DNS)
DUCKDNS_TOKEN=tu_token_de_duckdns

# Gmail SMTP Password (para notificaciones por email)
# Usa una contraseña de aplicación de Google, no tu contraseña normal
SMTP_PASSWORD=tu_contraseña_de_aplicacion_gmail
